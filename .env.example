# ─────────────────────────────────────────────────
# OpenAlex Explorer — environment variables
# ─────────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
#
#   cp .env.example .env.local
#
# All variables are optional.
# The app works without them using the public API.
# ─────────────────────────────────────────────────

# OpenAlex API key (optional)
# Grants access to the premium polite pool for higher rate limits.
# Get one at: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_API_KEY=
